# AllureGraph-AI Environment Configuration
# Copy to .env and fill in your values

# === LLM Providers ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://localhost:11434

# === Database ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Stripe Billing ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# === API Config ===
API_BASE_URL=https://graph.allurevips.fun
API_SECRET_KEY=your-secret-key-for-jwt
RATE_LIMIT_PER_MINUTE=60

# === Proxy (optional) ===
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# === AllureVIPs Integration ===
ALLUREVIPS_API_URL=https://app.allurevips.fun
ALLUREVIPS_SSO_SECRET=
